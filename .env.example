# Browser / Vite (safe to prefix with VITE_)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Convex CLI (from dashboard or `npx convex dev`)
CONVEX_DEPLOYMENT=dev:your-deployment

# Local app URL only — for your machine. Real secrets belong in Convex (dashboard or `npx convex env set`).
SITE_URL=http://localhost:3000
ADMIN_EMAILS=
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-5.1-mini
OPENAI_IMAGE_MODEL=gpt-image-2
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=openai/gpt-5.1-mini
DAILY_TEXT_GENERATION_LIMIT=20
DAILY_IMAGE_GENERATION_LIMIT=5
MAX_UPLOAD_BYTES=10485760

# --- Convex Auth: set on the Convex deployment, NOT in this file ---
# Convex Dashboard → Settings → Environment variables (same deployment as VITE_CONVEX_URL)
# Or: npx @convex-dev/auth  (generates keys and can set SITE_URL, etc.)
#
# Required for sign-in / JWTs:
#   JWT_PRIVATE_KEY   RSA private key (PKCS#8 PEM; CLI stores PEM newlines as spaces)
#   JWKS              JSON JWKS with the matching public key (set together with JWT_PRIVATE_KEY)
#
# Also required for OAuth + redirects (see https://labs.convex.dev/auth ):
#   CONVEX_SITE_URL   https://your-deployment.convex.site
#   SITE_URL          http://localhost:3000 (local) or https://your-prod-domain (prod)
#   AUTH_GOOGLE_ID    Google OAuth client ID
#   AUTH_GOOGLE_SECRET
#
# Google Cloud → Authorized redirect URI:
#   https://your-deployment.convex.site/api/auth/callback/google
